    "@mdx-js/react": "^2.3.0",
    "cross-env": "^7.0.3",
    "gatsby": "^5.16.1",
    "gatsby-plugin-emotion": "^8.16.0",
    "gatsby-plugin-feed": "^5.16.0",
    "gatsby-plugin-google-adsense": "^1.1.3",
    "gatsby-plugin-google-analytics": "^5.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-mdx": "^5.16.0",
    "gatsby-plugin-nprogress": "^5.16.0",
    "gatsby-plugin-page-creator": "^5.16.0",
    "gatsby-plugin-react-helmet": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
