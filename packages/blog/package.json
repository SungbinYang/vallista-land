{
  "name": "@vallista-land/blog",
  "version": "0.1.0",
  "private": true,
  "description": "template",
  "author": "vallista",
  "keywords": [
    "gatsby"
  ],
  "scripts": {
    "run:blog": "npx kill-port 8000 && gatsby develop",
    "build:blog": "cross-env GATSBY_EXPERIMENTAL_PAGE_BUILD_ON_DATA_CHANGES=true gatsby build --log-pages",
    "serve:blog": "gatsby serve",
    "clean:blog": "gatsby clean",
    "post:blog": "node ./scripts/create-post-file.js",
    "deploy:blog": "node ./scripts/deploy.js"
  },
  "dependencies": {
    "@SungbinYang/vallista-core": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
