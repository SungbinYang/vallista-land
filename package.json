{
  "name": "root",
  "private": true,
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "run:core": "pnpm --filter @SungbinYang/vallista-core run run:core",
    "build:core": "pnpm --filter @SungbinYang/vallista-core run build:core",
    "publish:core": "pnpm --filter @SungbinYang/vallista-core run publish:core",
    "run:playground": "pnpm --filter @vallista-land/playground run run:playground",
    "build:playground": "pnpm --filter @vallista-land/playground run build:playground",
    "clean:playground": "cd packages/playground && gatsby clean",
    "run:blog": "pnpm --filter @vallista-land/blog run run:blog",
    "build:blog": "pnpm --filter @vallista-land/blog run build:blog",
    "clean:blog": "cd packages/blog && gatsby clean",
    "post:blog": "cd packages/blog && pnpm post:blog",
    "deploy:blog": "cd packages/blog && pnpm deploy:blog",
    "directory:blog": "cd packages/blog",
    "deploy:blog-ex": "pnpm deploy:blog"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged --verbose"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": [
      "eslint --quiet --fix"
    ],
    "*.{json,md,html,js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  },
  "dependencies": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "core-js-pure",
      "es5-ext",
      "gatsby",
      "gatsby-cli",
      "lmdb",
      "msgpackr-extract",
      "nx",
      "sharp",
      "unrs-resolver"
    ]
  }
}
